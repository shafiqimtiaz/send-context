{
  "name": "ctx-handoff",
  "version": "0.1.4",
  "description": "Agent-agnostic CLI to relay AI coding-agent session context between developers via an encrypted, ephemeral edge link.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "ctx-handoff": "dist/index.js"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "handoff",
    "context",
    "claude-code",
    "opencode",
    "pi",
    "encryption"
  ],
  "homepage": "https://github.com/shafiqimtiaz/context-handoff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shafiqimtiaz/context-handoff.git"
  },
  "bugs": {
    "url": "https://github.com/shafiqimtiaz/context-handoff/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "release": "release-it"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "jsonrepair": "^3.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "release-it": "^20.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
