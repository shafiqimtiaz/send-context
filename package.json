{
  "name": "ctx-handoff",
  "version": "0.2.7",
  "description": "Agent-agnostic CLI to relay AI coding-agent session context between developers via an encrypted, ephemeral edge link.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "ctx-handoff": "dist/index.js"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "handoff",
    "context",
    "claude-code",
    "opencode",
    "pi",
    "encryption"
  ],
  "homepage": "https://github.com/shafiqimtiaz/ctx-handoff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shafiqimtiaz/ctx-handoff.git"
  },
  "bugs": {
    "url": "https://github.com/shafiqimtiaz/ctx-handoff/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && npm test",
    "release": "release-it",
    "release:patch": "release-it patch --no-git.tag",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "jsonrepair": "^3.14.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
